# Copy to .env.local and fill in secrets. Never commit .env.local.

# OpenAI (protocol parse + ranking rationale)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
EMBEDDING_MODEL=text-embedding-3-small
EXTRACTOR_MODEL=gpt-4.1

# Supabase (org claims + claim requests — required on Vercel)
# Project Settings → API: Project URL + service_role key (server only)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Claim requests — emailed to Intera for manual account setup
CLAIM_REQUEST_TO=christine_zhang@college.harvard.edu
# Optional: Resend for email delivery (https://resend.com)
RESEND_API_KEY=
RESEND_FROM=Intera Atlas <onboarding@resend.dev>
